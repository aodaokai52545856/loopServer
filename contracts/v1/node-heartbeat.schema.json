{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop-engine.internal/contracts/v1/node-heartbeat.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observedAt",
    "appliedRevision",
    "runner",
    "slots",
    "resources",
    "tools",
    "activeAttemptIds"
  ],
  "properties": {
    "observedAt": {"type": "string", "format": "date-time"},
    "appliedRevision": {"type": "integer", "minimum": 0},
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "version"],
      "properties": {
        "status": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "slots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active", "limit"],
      "properties": {
        "active": {"type": "integer", "minimum": 0},
        "limit": {"type": "integer", "minimum": 1, "maximum": 10}
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpuPercent", "memoryAvailableBytes", "diskAvailableBytes"],
      "properties": {
        "cpuPercent": {"type": "number", "minimum": 0},
        "memoryAvailableBytes": {"type": "integer", "minimum": 0},
        "diskAvailableBytes": {"type": "integer", "minimum": 0}
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "java", "maven", "node", "pnpm", "opencode"],
      "properties": {
        "os": {"type": "string", "minLength": 1},
        "arch": {"type": "string", "minLength": 1},
        "java": {"type": "string", "minLength": 1},
        "maven": {"type": "string", "minLength": 1},
        "node": {"type": "string", "minLength": 1},
        "pnpm": {"type": "string", "minLength": 1},
        "opencode": {"type": "string", "minLength": 1}
      }
    },
    "activeAttemptIds": {
      "type": "array",
      "items": {"type": "string", "format": "uuid"}
    },
    "lastError": {
      "type": ["string", "null"]
    }
  }
}
