<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <conversionRule conversionWord="redact"
                  class="com.company.loopengine.observability.SecretRedactingConverter"/>

  <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
      <layout class="com.company.loopengine.observability.JsonStructuredLayout">
        <serviceName>loop-engine-control-plane</serviceName>
      </layout>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="JSON"/>
  </root>
</configuration>
